# Local development (npm start): leave unset to use same-origin `/graphql` + CRA proxy
# to https://admin.yafel-properties.com (avoids HTTP→HTTPS redirect CORS in the browser).
#
# Production build: unset uses https://admin.yafel-properties.com/graphql in code.
# Or set explicitly for any environment:
# REACT_APP_GRAPHQL_ENDPOINT=https://admin.yafel-properties.com/graphql

# Laravel storage base for relative paths from the API (optional override)
# REACT_APP_STORAGE_BASE_URL=https://admin.yafel-properties.com/storage

# WhatsApp floating button fallback (digits only, country code + number). Used when CMS
# "consultant_whatsapp" is empty. CMS value wins when set in admin.
# Example: REACT_APP_WHATSAPP_NUMBER=201234567890
# REACT_APP_WHATSAPP_NUMBER=
